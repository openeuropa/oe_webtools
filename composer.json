{
    "name": "openeuropa/oe_webtools",
    "description": "OpenEuropa Webtools integration.",
    "type": "drupal-module",
    "license": "EUPL-1.2",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "drupal/core": "^10 || ^11",
        "ext-json": "*"
    },
    "require-dev": {
        "composer/installers": "~1.5",
        "drupal/captcha": "^1.10 || ^2.0",
        "drupal/core-composer-scaffold": "^10 || ^11",
        "drupal/core-dev": "^10 || ^11",
        "drupal/drupal-extension": "^5.0",
        "drupal/geocoder": "^4.0",
        "drupal/geofield": "^1.0",
        "drupal/json_field": "~1.1",
        "drush/drush": "^12 || ^13",
        "openeuropa/behat-transformation-context": "^0.2",
        "openeuropa/code-review-drupal": "^1.0.0-alpha",
        "openeuropa/oe_media": "dev-EWPP-4630",
        "openeuropa/oe_multilingual": "dev-EWPP-4627",
        "openeuropa/rdf_skos": "dev-EWPP-4616",
        "openeuropa/task-runner-drupal-project-symlink": "^1.0",
        "openeuropa/webtools-geocoding-provider": "^0.3"
    },
    "conflict": {
        "openeuropa/oe_webtools_location": "*"
    },
    "scripts": {
        "post-install-cmd": "./vendor/bin/run drupal:site-setup",
        "post-update-cmd": "./vendor/bin/run drupal:site-setup"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8",
            "exclude": [
                "drupal/file_link",
                "drupal/media_avportal",
                "drupal/remote_stream_wrapper"
            ]
        },
        {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/file_link-3430560.git",
            "reference": "e919bf13b4a14ac0bb1504bcbd04a80504466bb4"
        },
        {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/media_avportal-3431855.git",
            "reference": "1475bf7a0795f337cd007bc94780dc6041787cf3"
        },
        {
            "type": "package",
            "package": {
                "name": "drupal/remote_stream_wrapper",
                "version": "dev-d11-compatibility",
                "type": "drupal-module",
                "source": {
                    "type": "git",
                    "url": "https://git.drupalcode.org/issue/remote_stream_wrapper-3434168.git",
                    "reference": "5e9eb8d290f78f69464ab01ed374439992985811"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Drupal\\oe_webtools\\": "./src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\Tests\\oe_webtools\\": "./tests/"
        }
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "enable-patching": true,
        "installer-paths": {
            "build/core": ["type:drupal-core"],
            "build/profiles/contrib/{$name}": ["type:drupal-profile"],
            "build/modules/contrib/{$name}": ["type:drupal-module"],
            "build/themes/contrib/{$name}": ["type:drupal-theme"]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "./build"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "php-http/discovery": false,
            "phpro/grumphp": true,
            "phpro/grumphp-shim": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": false
        }
    }
}
